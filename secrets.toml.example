# COPY this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml should NEVER be committed to GitHub — add it to .gitignore.
#
# On Streamlit Community Cloud, you don't upload this file at all —
# you paste its contents into the app's "Secrets" settings in the
# dashboard instead (see README.md).

[auth]
username = "your-username"
password = "your-strong-password"

[gateway]
auth_key = "your-gateway-auth-key"
